  "challenges": [
    {
      "id": "ch-steady-50pct",
      "title": "50% Rejection Rate",
      "description": "Configure the token bucket so that exactly 50% of requests are rejected at steady state. If the refill rate is 4 tokens/second and bucket size is 4, what request rate would achieve exactly 50% rejection? Show your math.",
      "type": "optimize"
    },
    {
      "id": "ch-burst-allowed",
      "title": "Why Allow Bursts?",
      "description": "A customer complains: 'My app makes 100 API calls in 1 second every morning at 9am, then nothing for the rest of the hour.' Why is the Token Bucket better than a Fixed Window limiter for this use case? What bucket size should you configure?",
      "type": "scenario"
    },
    {
      "id": "ch-distributed",
      "title": "Distributed Rate Limiting",
      "description": "Your API runs on 10 servers. Each server runs its own token bucket limiter. A client sends 6 requests per second across all servers — each server allows 1 req/sec. What's the problem and how would you fix it?",
      "type": "break-it"
    }
  ]
}
