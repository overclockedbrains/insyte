      "showAtStep": 4,
      "hideAtStep": 6,
      "style": "info",
      "anchor": {
        "x": 50,
        "y": 15
      }
    }
  ],
  "challenges": [
    {
      "id": "ch-autocomplete",
      "title": "Build Autocomplete",
      "description": "Using the Trie structure, design an autocomplete function: given a prefix string, return all words that start with that prefix. What's the time complexity? How would you limit results to the top 5 most frequent words?",
      "type": "optimize"
    },
    {
      "id": "ch-delete-word",
      "title": "Delete a Word",
      "description": "Deleting a word from a Trie is tricky — you can't just remove the nodes because other words might share them. Design the delete algorithm. When can you safely delete a node, and when must you only clear the isEnd flag?",
      "type": "scenario"
    },
    {
      "id": "ch-count-prefixes",
      "title": "Count Words with Prefix",
      "description": "Add a `countStartsWith(prefix)` function that counts how many inserted words start with a given prefix. What extra state would you store in each node to make this O(m) instead of O(n)?",
      "type": "optimize"
    }
  ]
}
