    }
  ],

  "challenges": [
    {
      "id": "ch-worst-case",
      "title": "Force O(n) Performance",
      "description": "Design a set of keys that, with a bucket size of 7, all map to bucket index 0 (hash % 7 == 0). What's the time complexity of get() in this worst case? Why does Java use a Red-Black Tree instead of linked list when bucket length > 8?",
      "type": "break-it"
    },
    {
      "id": "ch-open-addressing",
      "title": "Open Addressing Alternative",
      "description": "Instead of chaining, Open Addressing stores colliding entries in the next available bucket (linear probing). What are the advantages and disadvantages vs chaining? When does open addressing perform better?",
      "type": "scenario"
    },
    {
      "id": "ch-custom-hashcode",
      "title": "Custom hashCode()",
      "description": "You have a `Point(x, y)` class. Two points with the same (x,y) values must be considered equal. Implement `hashCode()` and `equals()` for Point such that: (1) equal objects have equal hashes, (2) hash distribution is reasonably uniform.",
      "type": "optimize"
    }
  ]
