{
  "id": "sliding-window-max",
  "title": "Sliding Window Maximum",
  "type": "dsa-trace",
  "layout": "code-left-canvas-right",
  "description": "Use a monotonic deque to track max of each window.",
  "category": "Data Structures & Algorithms",
  "tags": [
    "sliding-window",
    "deque",
    "array"
  ],
  "code": {
    "language": "python",
    "source": "from collections import deque\n\ndef max_sliding_window(nums, k):\n    dq = deque()  # stores indices\n    out = []\n    for i, num in enumerate(nums):\n        while dq and dq[0] <= i - k:\n            dq.popleft()\n        while dq and nums[dq[-1]] <= num:\n            dq.pop()\n        dq.append(i)\n        if i >= k - 1:\n            out.append(nums[dq[0]])\n    return out\n\nfinalResult = max_sliding_window([1, 3, -1, -3, 5, 3, 6, 7], 3)\n",
    "highlightByStep": [
      0,
      5,
      8,
      9,
      10,
      6,
      8,
      11
    ]
  },
