  "explanation": [
    {
      "heading": "Monotonic Deque",
      "body": "Deque stores candidate indices in decreasing value order.",
      "appearsAtStep": 0
    },
    {
      "heading": "Drop Out-of-window and Smaller Values",
      "body": "Before appending current index, pop expired front and pop smaller values from back.",
      "appearsAtStep": 4
    },
    {
      "heading": "Front Is Window Max",
      "body": "At each full window, `nums[dq[0]]` is the maximum.",
      "appearsAtStep": 7
    }
  ],
