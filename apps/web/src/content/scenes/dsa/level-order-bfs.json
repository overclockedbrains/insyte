{
  "id": "level-order-bfs",
  "title": "Binary Tree Level Order Traversal",
  "type": "dsa-trace",
  "layout": "code-left-canvas-right",
  "description": "Traverse tree level by level using a queue (BFS).",
  "category": "Data Structures & Algorithms",
  "tags": [
    "bfs",
    "tree",
    "queue"
  ],
  "code": {
    "language": "python",
    "source": "from collections import deque\n\ndef level_order(root):\n    if not root:\n        return []\n    result = []\n    q = deque([root])\n    while q:\n        level_size = len(q)\n        level = []\n        for _ in range(level_size):\n            node = q.popleft()\n            level.append(node.val)\n            if node.left:\n                q.append(node.left)\n            if node.right:\n                q.append(node.right)\n        result.append(level)\n    return result\n",
    "highlightByStep": [
      6,
      7,
      10,
      12,
      13,
      10,
      12,
      13,
      15,
      16
    ]
  },
