  "explanation": [
    {
      "heading": "Halve the Search Space",
      "body": "Binary search relies on sorted order and discards half of the range each comparison.",
      "appearsAtStep": 0
    },
    {
      "heading": "Move Bounds",
      "body": "If `nums[mid] < target`, move `lo` right. If greater, move `hi` left.",
      "appearsAtStep": 2
    },
    {
      "heading": "Hit Condition",
      "body": "As soon as `nums[mid] == target`, return `mid`.",
      "appearsAtStep": 4
    }
