  "code": {
    "language": "python",
    "source": "def binary_search(nums, target):\n    lo, hi = 0, len(nums) - 1\n    while lo <= hi:\n        mid = (lo + hi) // 2\n        if nums[mid] == target:\n            return mid\n        if nums[mid] < target:\n            lo = mid + 1\n        else:\n            hi = mid - 1\n    return -1\n\nfinalResult = binary_search([1, 3, 5, 7, 9, 11], 9)\n",
    "highlightByStep": [
      0,
      2,
      3,
      6,
      3,
      4
    ]
  },
