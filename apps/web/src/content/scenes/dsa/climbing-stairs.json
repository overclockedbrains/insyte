  "id": "climbing-stairs",
  "title": "Climbing Stairs (DP)",
  "type": "dsa-trace",
  "layout": "code-left-canvas-right",
  "description": "Count ways to reach step n using bottom-up dynamic programming.",
  "category": "Data Structures & Algorithms",
  "tags": [
    "dynamic-programming",
    "dp-table",
    "fibonacci"
  ],
  "code": {
    "language": "python",
    "source": "def climb_stairs(n):\n    if n <= 2:\n        return n\n    dp = [0] * (n + 1)\n    dp[1], dp[2] = 1, 2\n    for i in range(3, n + 1):\n        dp[i] = dp[i - 1] + dp[i - 2]\n    return dp[n]\n\nfinalResult = climb_stairs(5)\n",
    "highlightByStep": [
      0,
      3,
      4,
      5,
      6,
      6,
      6,
      7
    ]
  },
