  ],
  "code": {
    "language": "python",
    "source": "class Node:\n    def __init__(self, value, nxt=None):\n        self.value = value\n        self.next = nxt\n\ndef reverse(head):\n    prev = None\n    curr = head\n    while curr:\n        nxt = curr.next\n        curr.next = prev\n        prev = curr\n        curr = nxt\n    return prev\n\nfinalResult = reverse(Node(1, Node(2, Node(3, Node(4)))))\n",
    "highlightByStep": [
      5,
      8,
      9,
      10,
      11,
      12
    ]
  },
