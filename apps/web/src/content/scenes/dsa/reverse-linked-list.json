  "explanation": [
    {
      "heading": "Three Pointers",
      "body": "Maintain `prev`, `curr`, and `nxt` so links can be reversed safely.",
      "appearsAtStep": 0
    },
    {
      "heading": "Rewire One Node Per Iteration",
      "body": "Each loop detaches `curr` from forward direction and points it to `prev`.",
      "appearsAtStep": 1
    },
    {
      "heading": "In-place Reverse",
      "body": "No extra list is created. Pointer rewiring gives O(1) auxiliary space.",
      "appearsAtStep": 4
    }
