  "code": {
    "language": "python",
    "source": "def two_sum(nums, target):\n    seen = {}\n    for i, num in enumerate(nums):\n        need = target - num\n        if need in seen:\n            return [seen[need], i]\n        seen[num] = i\n    return []\n\nfinalResult = two_sum([2, 7, 11, 15], 9)\n",
