  "code": {
    "language": "python",
    "source": "def fib(n, memo):\n    if n in memo:\n        return memo[n]\n    if n <= 1:\n        return n\n    memo[n] = fib(n - 1, memo) + fib(n - 2, memo)\n    return memo[n]\n\nfinalResult = fib(5, {})\n",
