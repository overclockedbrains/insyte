{
  "id": "number-of-islands",
  "title": "Number of Islands",
  "type": "dsa-trace",
  "layout": "code-left-canvas-right",
  "description": "Count connected land components with flood fill on a grid.",
  "category": "Data Structures & Algorithms",
  "tags": ["grid", "dfs", "flood-fill"],
  "code": {
    "language": "python",
    "source": "def num_islands(grid):\n    rows, cols = len(grid), len(grid[0])\n    seen = set()\n\n    def dfs(r, c):\n        if r < 0 or c < 0 or r >= rows or c >= cols:\n            return\n        if grid[r][c] == '0' or (r, c) in seen:\n            return\n        seen.add((r, c))\n        dfs(r + 1, c)\n        dfs(r - 1, c)\n        dfs(r, c + 1)\n        dfs(r, c - 1)\n\n    islands = 0\n    for r in range(rows):\n        for c in range(cols):\n            if grid[r][c] == '1' and (r, c) not in seen:\n                islands += 1\n                dfs(r, c)\n    return islands\n",
    "highlightByStep": [14, 17, 18, 8, 19, 17, 19, 20]
  },
