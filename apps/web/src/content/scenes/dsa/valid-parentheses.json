  "description": "Validate bracket strings using a stack.",
  "category": "Data Structures & Algorithms",
  "tags": ["stack", "parentheses", "strings"],
  "code": {
    "language": "python",
    "source": "def is_valid(s):\n    pairs = {')': '(', ']': '[', '}': '{'}\n    stack = []\n    for ch in s:\n        if ch in '([{':\n            stack.append(ch)\n        else:\n            if not stack or stack[-1] != pairs[ch]:\n                return False\n            stack.pop()\n    return len(stack) == 0\n\nfinalResult = is_valid('()[]{}')\n",
    "highlightByStep": [0, 4, 5, 4, 8, 4, 8, 10]
  },
