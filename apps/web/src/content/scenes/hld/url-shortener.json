  "explanation": [
    {
      "heading": "URL Shortener: Read-Heavy System",
      "body": "A URL shortener is **100:1 read-to-write**. Once shortened, a URL is resolved millions of times.\n\nDesign centers around making reads as fast as possible.",
      "appearsAtStep": 0
    },
    {
      "heading": "Write Path: Generate Short ID",
      "body": "**PUT /shorten**: API generates a 6-character Base62 ID (62^6 = 56 billion possible IDs) and stores the mapping in the database.\n\nBase62 uses [a-z A-Z 0-9] for URL-safe IDs.",
      "appearsAtStep": 1
    },
    {
      "heading": "Read Path: Cache-First",
      "body": "**GET /abc123**: Check Redis first (sub-ms latency). Cache hit rate > 80% for popular URLs.\n\nOnly fall through to DB on a miss. Write result back to cache for next time.",
      "appearsAtStep": 3
    },
    {
      "heading": "CDN for Maximum Speed",
      "body": "For highly popular URLs, cache the redirect at CDN edge nodes globally.\n\nThe redirect never reaches your origin servers — pure edge resolution at <10ms from anywhere.",
      "appearsAtStep": 7
    }
  ],
  "popups": [
    {
      "id": "pop-base62",
      "attachTo": "url-system",
      "text": "Base62: [a-z A-Z 0-9] = URL-safe IDs",
      "showAtStep": 2,
      "hideAtStep": 3,
      "style": "info",
      "anchor": {
        "x": 55,
        "y": 25
      }
    },
    {
      "id": "pop-301-vs-302",
      "attachTo": "url-system",
      "text": "301 = permanent (browser caches). 302 = temporary (always hits your server).",
      "showAtStep": 4,
      "hideAtStep": 6,
      "style": "insight",
      "anchor": {
        "x": 30,
        "y": 75
      }
    }
  ],
  "challenges": [
    {
      "id": "ch-301-vs-302",
      "title": "301 vs 302 Redirect",
      "description": "Should the short URL redirect use HTTP 301 (Permanent) or 302 (Temporary)? 301 means browsers cache the redirect and never call your server again — great for performance but you lose click analytics. 302 hits your server every time. Which would you choose for a business? Why?",
      "type": "scenario"
    },
    {
      "id": "ch-collision",
      "title": "ID Collision",
      "description": "Two users submit different long URLs that hash to the same short ID. How do you handle this? Design the put() algorithm to guarantee uniqueness. What happens when the ID space (62^6 = 56B) fills up?",
      "type": "break-it"
    },
    {
      "id": "ch-scale",
      "title": "10B URLs, 100M resolutions/day",
      "description": "The system needs to handle 10 billion stored URLs and 100 million resolutions per day. Walk through the capacity estimates: storage size, cache memory needed, DB read QPS, required DB sharding strategy.",
      "type": "optimize"
    }
  ]
}
