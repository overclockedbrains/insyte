  "challenges": [
    {
      "id": "ch-naive-vs-consistent",
      "title": "Naive vs Consistent — The Math",
      "description": "You have a cache cluster with 4 servers storing 1 million keys. You add a 5th server. With naive modulo hashing (hash % N), how many keys need to remigrate? With consistent hashing, how many? Show the calculation for both.",
      "type": "predict"
    },
    {
      "id": "ch-hotspot",
      "title": "Hot Spot Without Virtual Nodes",
      "description": "With only 3 servers on a ring and uniformly distributed key hashes, Server A covers 60% of the ring arc, B covers 25%, C covers 15%. What's the load imbalance? How many virtual nodes per server would reduce the standard deviation of loads to under 5%?",
      "type": "optimize"
    },
    {
      "id": "ch-replication",
      "title": "Replication with Consistent Hashing",
      "description": "DynamoDB replicates each key on the next N servers clockwise (N=3 by default). When Server B goes down, which servers now serve its keys? Draw the replica assignment for 4 servers and 5 keys from the simulation.",
      "type": "scenario"
    }
  ]
