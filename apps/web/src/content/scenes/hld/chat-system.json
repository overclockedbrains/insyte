      "showAtStep": 4,
      "hideAtStep": 5,
      "style": "warning",
      "anchor": { "x": 50, "y": 85 }
    }
  ],

  "challenges": [
    {
      "id": "ch-server-selection",
      "title": "WebSocket Server Selection",
      "description": "Client A is connected to WS Server 1, Client B to WS Server 2. How does Server 1 know which server to forward the message to? Design the routing mechanism using a service discovery layer (e.g., Redis with userId → serverId mapping).",
      "type": "scenario"
    },
    {
      "id": "ch-delivery-guarantees",
      "title": "Exactly-Once Delivery",
      "description": "The Message Queue guarantees at-least-once delivery. But if Server 2 crashes after receiving but before acknowledging, the message gets re-delivered and Client B sees it twice. How would you implement exactly-once delivery? What's the cost?",
      "type": "break-it"
    },
    {
      "id": "ch-group-chat",
      "title": "Extend to Group Chat",
      "description": "Design group chat with 1000 members. When a message is sent, it needs to reach all 1000 members. Should you use fanout-on-write (pre-push to all) or fanout-on-read (store once, fetch on demand)? What's the crossover point?",
      "type": "optimize"
    }
  ]
}
