  "explanation": [
    {
      "heading": "The Fanout Problem",
      "body": "When user A posts a tweet, it must appear in the feeds of all their followers. \"Fanning out\" to N followers is the core challenge.\n\nTwitter serves **hundreds of millions of timelines** — reads happen 100× more than writes.",
      "appearsAtStep": 0
    },
    {
      "heading": "Fanout-on-Write",
      "body": "When a tweet is posted, immediately **push it into every follower's feed cache**.\n\n✓ Fast reads: feed is pre-computed, O(1) cache lookup\n✗ Slow writes: N cache updates per tweet (N = follower count)",
      "appearsAtStep": 2
    },
    {
      "heading": "The Celebrity Problem",
      "body": "With Fanout-on-Write, a tweet from a 50M-follower account triggers **50 million cache writes** in seconds.\n\nThis is a write storm — the Fanout Service gets overwhelmed, latency spikes, users notice.",
      "appearsAtStep": 4
    },
    {
      "heading": "Hybrid Solution",
      "body": "Twitter's actual solution:\n- **Regular users** (< ~1M followers): fanout-on-write as normal\n- **Celebrities**: skip fanout — tweet lives only in Tweet DB\n\nOn read: merge the user's pre-built feed cache with the celebrity's tweet from DB.\n\nSmall overhead per read, but avoids the write storm.",
      "appearsAtStep": 5
    }
  ],

  "popups": [
    {
      "id": "pop-fanout-cost",
      "attachTo": "twitter-system",
      "text": "1000 followers = 1000 cache writes per tweet",
      "showAtStep": 2,
      "hideAtStep": 4,
      "style": "info",
      "anchor": { "x": 70, "y": 80 }
    },
    {
      "id": "pop-celebrity-storm",
      "attachTo": "twitter-system",
      "text": "50M writes in seconds — system collapses!",
      "showAtStep": 4,
      "hideAtStep": 5,
      "style": "warning",
      "anchor": { "x": 50, "y": 80 }
    }
  ],

  "challenges": [
    {
      "id": "ch-fanout-read",
      "title": "Fanout-on-Read Trade-off",
      "description": "Design the Fanout-on-Read approach: when a user requests their feed, fetch tweets from all followed accounts' tweet DBs and merge them. What's the time complexity? Why does this approach fail at Twitter's scale?",
      "type": "scenario"
    },
    {
      "id": "ch-threshold",
      "title": "Celebrity Threshold",
      "description": "At what follower count should Twitter switch from fanout-on-write to the hybrid approach? Assume: 10ms per cache write, fanout must complete in <100ms total, writes are parallelized across 100 workers. Calculate the threshold.",
      "type": "optimize"
    },
    {
      "id": "ch-unfollow",
      "title": "Unfollow Problem",
      "description": "User unfollows someone mid-session. Their pre-built feed cache still contains tweets from the unfollowed account. How do you handle this? Should you invalidate the cache immediately? What consistency level is acceptable for a social feed?",
      "type": "break-it"
    }
  ]
}
