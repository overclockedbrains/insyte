      "attachTo": "lb-system",
      "text": "Consider horizontal auto-scaling!",
      "showAtStep": 9,
      "style": "insight"
    }
  ],

  "challenges": [
    {
      "id": "ch-sticky-session",
      "title": "Sticky Sessions Problem",
      "description": "Imagine a user logs in and their session is stored in Server 1's memory. The next request goes to Server 2 (round robin) — they're logged out! How would you solve this without changing the load balancing algorithm?",
      "type": "scenario"
    },
    {
      "id": "ch-two-servers-fail",
      "title": "Two Servers Fail Simultaneously",
      "description": "Kill Server 1 and Server 3 using the controls, leaving only Server 2. What happens to your request rate? What's the minimum number of servers you'd run in production for a service that needs 99.9% uptime?",
      "type": "break-it"
    },
    {
      "id": "ch-optimal-weights",
      "title": "Optimize Weights",
      "description": "You have 3 servers: S1 (4-core), S2 (8-core), S3 (16-core). What weights would you assign to make each server process the same percentage of its capacity? Show your calculation.",
      "type": "optimize"
    }
  ]
}
