      "showAtStep": 8,
      "hideAtStep": 9,
      "style": "insight"
    }
  ],

  "challenges": [
    {
      "id": "ch-cache-off",
      "title": "Cache Off — Count the Hops",
      "description": "Disable the browser cache using the toggle above, then step through the simulation. Count exactly how many network round-trips happen for a cold lookup. Now re-enable cache and check the second request — what's the ratio?",
      "type": "predict"
    },
    {
      "id": "ch-ttl-tradeoff",
      "title": "TTL Trade-off Decision",
      "description": "You're deploying insyte.dev to a new IP address. Your current TTL is 3600s (1 hour). How long will it take for all users worldwide to see the new IP? What TTL would you set 24 hours before the migration? After?",
      "type": "scenario"
    },
    {
      "id": "ch-dns-poisoning",
      "title": "DNS Cache Poisoning",
      "description": "A malicious resolver returns a fake IP for insyte.dev, pointing to an attacker's server. The browser caches it. What prevents this attack in modern DNS? Look up DNSSEC.",
      "type": "break-it"
    }
  ]
}
