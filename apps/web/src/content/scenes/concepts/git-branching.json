  "challenges": [
    {
      "id": "ch-merge-vs-rebase",
      "title": "Merge vs Rebase Trade-off",
      "description": "Your team follows a rule: all PRs must be rebased before merging. What problem does this solve vs. always using merge commits? What's the downside if someone force-pushes a rebased branch that others have checked out?",
      "type": "predict"
    },
    {
      "id": "ch-detached-head",
      "title": "Detached HEAD State",
      "description": "Run `git checkout C2` (a commit hash instead of a branch name). You're now in detached HEAD state. If you commit from here, what happens when you checkout main again? How do you save those commits?",
      "type": "scenario"
    },
    {
      "id": "ch-recover-reset",
      "title": "Recover After git reset --hard",
      "description": "You accidentally ran `git reset --hard HEAD~3` and lost 3 commits. The commits aren't on any branch. How do you recover them? Hint: `git reflog` is your friend.",
      "type": "break-it"
    }
  ]
