# ── AI (server-side) ─────────────────────────────────────────────────────────
# Free tier — Gemini Flash used for all server-side generation
NEXT_PUBLIC_APP_URL=https://insyte.amanarya.com

# ── Supabase (server-side) ────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
GEMINI_API_KEY=

# ── Dev env variables ────────────────────────────────────────────────────
# BYOK keys for OpenAI, Anthropic, and Groq are intentionally not stored here.
# They are saved in the user's browser localStorage from the Settings page.

# ── Notes ─────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_APP_URL is used for canonical metadata and share links.
# NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY are required in the browser.
# SUPABASE_SERVICE_ROLE_KEY is required for server-side caching, seeding, and rate limiting.
# GEMINI_API_KEY powers the default non-BYOK generation flow.
