# Google Gemini API key — powers default non-BYOK scene generation
GEMINI_API_KEY=your_gemini_api_key_here

# Your Supabase project URL — found in Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous/public key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_anon_key

# Supabase publishable default key — alias for anon key used by newer Supabase SDK versions
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_your_key

# Supabase service role key (server-side only) — required for caching, seeding, and rate limiting
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_service_role_key

# Canonical app URL — used for metadata tags and share link generation
NEXT_PUBLIC_APP_URL=https://insyte.amanarya.com

# Enable verbose AI debug logging in the browser console
NEXT_PUBLIC_DEBUG_AI=true

# Show layout debug borders around components in development
NEXT_PUBLIC_DEV_BORDERS=false

# Log full AI prompts server-side (can be very verbose)
DEBUG_AI_FULL_PROMPTS=false

# Renderer backend — "dom" uses React DOM, "canvas" uses a canvas-based renderer
NEXT_PUBLIC_RENDERER=dom

# Server-side per-stage retry budget inside pipeline.ts — set to 0 to fail fast in dev
PIPELINE_MAX_RETRIES=1

# Client-side full-request retry budget in useStreamScene — set to 0 to fail fast in dev
NEXT_PUBLIC_CLIENT_MAX_RETRIES=1

# Enable /dev/* routes (Pipeline Playground, Scene Studio) — leave unset or false in production
NEXT_PUBLIC_DEV_TOOLS=true
