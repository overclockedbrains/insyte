{
  "name": "insyte",
  "version": "1.1.0",
  "description": "An AI-powered interactive learning platform for live algorithmic traces and system design simulations.",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "validate-scenes": "pnpm --filter web validate-scenes",
    "clean": "turbo clean && pnpm -r exec rimraf .next dist .turbo tsconfig.tsbuildinfo",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "setup-symlinks": "bash scripts/setup-symlinks.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/overclockedbrains/insyte.git"
  },
  "author": "Aman Arya (Am4nn)",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/overclockedbrains/insyte/issues"
  },
  "homepage": "https://github.com/overclockedbrains/insyte#readme",
  "devDependencies": {
    "prettier": "^3.4.2",
    "rimraf": "^6.1.3",
    "turbo": "^2.3.3"
  }
}